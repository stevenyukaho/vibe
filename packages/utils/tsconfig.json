{
	"compilerOptions": {
		"target": "ES2019",
		"module": "commonjs",
		"declaration": true,
		"declarationMap": true,
		"outDir": "dist",
		"rootDir": "src",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"composite": true
	},
	"include": ["src/**/*.ts"],
	"exclude": ["dist", "node_modules"]
}
