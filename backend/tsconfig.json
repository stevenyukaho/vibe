{
    "compilerOptions": {
        "target": "es2020",
        "module": "commonjs",
        "lib": [
            "es2020"
        ],
        "strict": true,
        "noImplicitReturns": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "outDir": "./dist",
        "rootDir": "../",
        "moduleResolution": "node",
        "resolveJsonModule": true
    },
    "include": [
        "src/**/*",
        "../types/**/*.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}
