{
  "compilerOptions": {
    "target": "es2016",
    "module": "commonjs",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true,
    "outDir": "dist",
		"rootDir": "./src",
		"resolveJsonModule": true,
		"baseUrl": ".",
		"paths": {
			"@ibm-vibe/types": ["../packages/types/index"],
			"@ibm-vibe/config": ["../packages/config/src/index"]
		},
		"composite": true
  },
  "include": [
		"src"
  ],
	"exclude": ["node_modules", "**/*.test.ts"],
	"references": [
		{ "path": "../packages/types" },
		{ "path": "../packages/config" }
	]
}
