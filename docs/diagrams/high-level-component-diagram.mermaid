graph TB
    subgraph "AI Agent Testing Suite"
        Frontend[Frontend<br>Next.js + React]
        Backend[Backend<br>Express.js + TypeScript]
        AgentService[Agent Service<br>FastAPI + CrewAI]
        FutureAgents[Future Agent Services]
        
